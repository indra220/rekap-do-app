{
  "name": "rekap-do-app",
  "version": "1.0.36",
  "description": "Aplikasi Rekapitulasi Delivery Order (DO) Pupuk",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"next dev\" \"cross-env WAITING_DIST=false electron .\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "pack": "next build && electron-builder --dir",
    "dist": "next build && electron-builder",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-builder install-app-deps"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/indra220/rekap-do-app.git"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "electron-serve": "^1.3.0",
    "electron-updater": "^6.8.9",
    "exceljs": "^3.4.0",
    "file-saver": "^2.0.5",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.475.0",
    "next": "^16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^24.13.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^11.0.0",
    "electron": "^40.10.2",
    "electron-builder": "^26.15.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.1.7",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "glob": "^10.3.10",
    "rimraf": "^5.0.5",
    "inflight": "^1.0.6",
    "are-we-there-yet": "^4.0.0",
    "gauge": "^5.0.0",
    "npmlog": "^7.0.0"
  },
  "build": {
    "appId": "com.megaagrosanjaya.rekapdo",
    "productName": "Aplikasi Rekap DO",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Aplikasi Rekap DO",
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "uninstallDisplayName": "Uninstall Aplikasi Rekap DO",
      "differentialPackage": true,
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "unicode": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "indra220",
        "repo": "rekap-do-app",
        "releaseType": "release"
      }
    ],
    "win": {
      "icon": "app/favicon.ico",
      "target": "nsis"
    },
    "files": [
      "out/**/*",
      "main.js",
      "package.json"
    ]
  }
}
